# Python environments - jangan upload virtualenv
.venv/
venv/
env/

# Python cache and test output
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Local environment files - boleh upload .env.example saja
.env
.env.*
!.env.example
.agents/
.commandcode/

# SQLite and local runtime data - database demo dibuat lokal
*.db
*.sqlite
*.sqlite3

# Dataset asli/eksperimen - jangan upload dataset Kaggle atau hasil notebook
results/
stunting_wasting_dataset.csv
modelstunting.ipynb
.ipynb_checkpoints/
backend/data/*.csv
!backend/data/sample_stunting_data.csv

# ML artifacts
# Default: ignore artifact hasil training lokal agar metrics sample/dataset pribadi tidak ikut terupload.
backend/app/ml/model_artifacts/*
!backend/app/ml/model_artifacts/.gitkeep

# Exception: artifact kecil ini boleh diupload agar demo bisa langsung menjalankan prediksi.
!backend/app/ml/model_artifacts/stunting_model.joblib
!backend/app/ml/model_artifacts/scaler.joblib
!backend/app/ml/model_artifacts/normal_values.csv

# Jangan upload artifact besar/alternatif yang tidak dipakai runtime demo.
*.h5
*.keras
*.onnx
*.pkl
*.pickle

# Frontend dependencies and build output
node_modules/
frontend/node_modules/
.vite/
frontend/.vite/
dist/
frontend/dist/
*.tsbuildinfo
frontend/vite.config.js
frontend/vite.config.d.ts

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS/editor files
.DS_Store
Thumbs.db
.idea/
.vscode/

