# StuntGuard local environment example
# Copy to .env in the project root or backend/.env, then fill only the keys you use.

# Backend
# DATABASE_URL is optional. By default, backend uses backend/stuntguard.db.
# DATABASE_URL=sqlite:///backend/stuntguard.db
# Set a stable random secret outside local development so demo sessions remain
# valid across server restarts. Example generator: python -c "import secrets; print(secrets.token_urlsafe(48))"
STUNTGUARD_SECRET_KEY=
DEMO_AUTH_TOKEN_TTL_SECONDS=28800
DEMO_PARENT_PASSWORD=password
DEMO_ADMIN_PASSWORD=password
LOGIN_MAX_ATTEMPTS_PER_MINUTE=10
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# Enable only when requests arrive through a trusted reverse proxy that rewrites X-Forwarded-For.
TRUST_PROXY_HEADERS=false
LLM_PROVIDER=chain

# Gemini is the recommended primary provider for demo use.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_FALLBACK_MODEL=gemini-1.5-flash

# Optional providers. Leave empty unless LLM_PROVIDER uses them.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-lite-001
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=StuntGuard

# LLM fallback and output size
LLM_MAX_OUTPUT_TOKENS=250
LLM_FALLBACK_CHAIN=gemini:gemini-2.5-flash-lite,gemini:gemini-2.0-flash-lite,gemini:gemini-1.5-flash,groq:llama-3.1-8b-instant,openrouter:google/gemini-2.0-flash-lite-001

# Local chatbot usage limit.
# This is app-level quota, separate from Gemini/Groq/OpenRouter quota.
CHAT_RATE_LIMIT_ENABLED=true
CHAT_GUEST_DAILY_LIMIT=100
CHAT_GUEST_MINUTE_LIMIT=10
CHAT_PARENT_DAILY_LIMIT=200
CHAT_PARENT_MINUTE_LIMIT=20
CHAT_ADMIN_DAILY_LIMIT=500
CHAT_ADMIN_MINUTE_LIMIT=50
# Use "all" for demo protection, or "llm" so fallback/guardrail answers do not consume local quota.
CHAT_LIMIT_COUNT_SOURCES=all

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000
